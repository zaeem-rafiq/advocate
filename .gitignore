__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.env
.env.*
!.env.example
*-key.json
service-account*.json
.DS_Store
.claude/skill-usage.log
# agent-skills hook runtime caches (never commit)
.claude/sdd-cache/
.claude/.simplify-ignore-cache/
uv.lock
orchestrator-data/
# ADK local runtime cache (per-app session/state) — must never ship in the Cloud Run
# image. `.gcloudignore` does `#!include:.gitignore`, so listing it here also keeps a
# `gcloud run deploy --source .` build context clean (e.g. agent_apps/<app>/.adk/).
.adk/
# local UI verification artifacts (Playwright MCP screenshots + scratch) — never commit.
# No PNGs are tracked at the repo root; real image assets live under subdirectories.
.playwright-mcp/
/*.png
# Submission workspace (judge access notes/credentials, contest drafts) — lives ONLY in
# the main worktree and must NEVER be tracked or pushed to this public repo.
submission/
